{
  "info": {
    "_postman_id": "robin-hoot-api",
    "name": "Robin HOOT API",
    "description": "Colección completa de endpoints de la API Robin HOOT — quizzes interactivos en tiempo real.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 - Usuario creado', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Respuesta tiene message', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/auth/registrar" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana García\",\n  \"email\": \"ana@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - Login exitoso', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta tiene message', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('message');",
                  "});",
                  "pm.test('Cookie token seteada', function () {",
                  "  pm.expect(pm.cookies.has('token')).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login - Credenciales inválidas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400 - Credenciales inválidas', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Respuesta tiene message de error', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/auth/login" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - Logout exitoso', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/usuarios/auth/logout" }
          }
        },
        {
          "name": "Perfil (protegido)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 o 401', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
                  "});",
                  "pm.test('Respuesta es JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/usuarios/perfil" }
          }
        }
      ]
    },
